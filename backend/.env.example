# --- Database (pick ONE) ---
#
# A) Docker: install Docker Desktop, then from project root: docker compose up -d
# DATABASE_URL=postgresql+psycopg2://studycanvas:studycanvas@localhost:5432/studycanvas
#
# B) PostgreSQL installed on Windows (no Docker) — use your postgres user/password
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/studycanvas
#
# C) Windows install (winget / postgresql.org) — use your postgres password
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/studycanvas

# Auth
JWT_SECRET=change-me-in-production

# LLM: openai (Groq) | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
# Groq vision (replaces decommissioned llama-3.2-11b-vision-preview)
OPENAI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Local fallback (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=moondream

# Intent classifier: distilbert (production) | tfidf (baseline only)
INTENT_MODEL=distilbert
