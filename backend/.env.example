# --- Database (pick ONE) ---
#
# A) Docker: install Docker Desktop, then from project root: docker compose up -d
# DATABASE_URL=postgresql+psycopg2://studycanvas:studycanvas@localhost:5432/studycanvas
#
# B) PostgreSQL installed on Windows (no Docker) — use your postgres user/password
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/studycanvas
#
# C) Windows install (winget / postgresql.org) — use your postgres password
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/studycanvas

# Auth
JWT_SECRET=change-me-in-production

# LLM: ollama | openai
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.2:3b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
